{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "VideoMemo",
  "version": "2.3.5",
  "identifier": "com.videomemo.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3015",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build --mode tauri "
  },
  "app": {
    "windows": [
      {
        "title": "VideoMemo",
        "width": 1600,
        "height": 1000,
        "resizable": true,
        "fullscreen": false,
        "devtools": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "externalBin": [
      "bin/VideoMemoBackend/VideoMemoBackend"
    ],
    "macOS":{
      "files": {
               "Frameworks": "bin/VideoMemoBackend/_internal"
      }
    },
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}